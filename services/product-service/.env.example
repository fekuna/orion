# Application
APP_NAME=product-service
APP_ENV=local
APP_DEBUG=true

# Logging (debug | info | warn | error)
LOG_LEVEL=debug

# HTTP Server
HTTP_HOST=
HTTP_PORT=8080
HTTP_ALLOWED_ORIGINS=*

# Database
# When running locally with docker compose:
#   host = db (compose service name), port = 5432
# When running outside docker:
#   host = localhost, port = 5432 (or POSTGRES_PORT from root .env)
DATABASE_DSN=postgres://orion:orion_secret@localhost:5432/product_db?sslmode=disable
